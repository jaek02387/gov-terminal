# Copy this file to ".env" and fill in your keys.
#   cp .env.example .env
#
# Congress.gov key (required for bill panels): https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# LegiScan key (OPTIONAL fallback). Leave blank to keep it dormant.
# Get one at https://legiscan.com/legiscan if you want the fallback active.
LEGISCAN_API_KEY=

# Optional: override the background refresh cadence (minutes). Default 60.
REFRESH_INTERVAL_MINUTES=60

# --- Optional stock-news providers ---------------------------------------
# Stock news works out of the box via free yfinance news. Add either key below
# to upgrade to a curated provider (the chain prefers Finnhub, then Marketaux,
# then yfinance). Leave blank to keep dormant.
#
# Finnhub (recommended; free 60 calls/min): https://finnhub.io/
FINNHUB_API_KEY=
# Marketaux (free 100/day): https://www.marketaux.com/
MARKETAUX_API_KEY=
# Optional: restrict Marketaux to specific source domains for neutrality,
# e.g. apnews.com,reuters.com  (blank = all sources)
MARKETAUX_DOMAINS=
