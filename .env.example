# Copy this file to ".env" and fill in your keys.
#   cp .env.example .env
#
# Congress.gov key (required for bill panels): https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# LegiScan key (OPTIONAL fallback). Leave blank to keep it dormant.
# Get one at https://legiscan.com/legiscan if you want the fallback active.
LEGISCAN_API_KEY=

# Optional: override the background refresh cadence (minutes). Default 60.
REFRESH_INTERVAL_MINUTES=60
